<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Android 11+ 包可见性：查询已启用输入法列表时需要，否则部分 ROM 上可能异常 -->
    <queries>
        <intent>
            <action android:name="android.view.InputMethod" />
        </intent>
    </queries>

    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name=".MoqiApplication"
        android:usesCleartextTraffic="true"
        android:allowBackup="false"
        android:icon="@drawable/mo_icon"
        android:roundIcon="@drawable/mo_icon"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.MoqiIM">

        <activity
            android:name=".settings.SetupActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.MoqiIM">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".settings.SettingsActivity"
            android:exported="true"
            android:label="@string/settings_title"
            android:theme="@style/Theme.MoqiIM" />

        <activity
            android:name=".settings.InputTestActivity"
            android:exported="true"
            android:label="@string/input_test_title"
            android:windowSoftInputMode="stateAlwaysVisible|adjustResize"
            android:theme="@style/Theme.MoqiIM" />

        <service
            android:name=".core.MoqiInputMethodService"
            android:exported="true"
            android:label="@string/ime_label"
            android:permission="android.permission.BIND_INPUT_METHOD">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/input_method" />
        </service>

    </application>

</manifest>